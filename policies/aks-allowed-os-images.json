{
  "mode": "Indexed",
  "policyRule": {
    "if": {
      "allOf": [
        {
          "field": "type",
          "equals": "Microsoft.ContainerService/managedClusters/agentPools"
        },
        {
          "not": {
            "anyOf": [
              {
                "allOf": [
                  {
                    "field": "Microsoft.ContainerService/managedClusters/agentPools/osSKU",
                    "in": "[parameters('allowedOsSKUs')]"
                  },
                  {
                    "field": "Microsoft.ContainerService/managedClusters/agentPools/osType",
                    "equals": "Linux"
                  }
                ]
              }
            ]
          }
        }
      ]
    },
    "then": {
      "effect": "[parameters('effect')]"
    }
  },
  "parameters": {
    "effect": {
      "type": "String",
      "metadata": {
        "displayName": "Effect",
        "description": "The effect to apply when the policy is violated."
      },
      "allowedValues": [
        "Audit",
        "Deny",
        "Disabled"
      ],
      "defaultValue": "Deny"
    },
    "allowedOsSKUs": {
      "type": "Array",
      "metadata": {
        "displayName": "Allowed OS SKUs",
        "description": "The list of allowed Linux OS image SKUs for AKS node pools. Windows SKUs are explicitly blocked."
      },
      "defaultValue": [
        "AzureLinux",
        "Mariner",
        "CBLMariner"
      ],
      "allowedValues": [
        "AzureLinux",
        "Mariner",
        "CBLMariner"
      ]
    }
  },
  "metadata": {
    "displayName": "AKS clusters should only use approved Linux OS image SKUs",
    "description": "Restricts AKS node pools to approved Linux-only OS images: AzureLinux (v3/v4) and CBL-Mariner. Explicitly denies Windows node pools and Ubuntu. Only hardened, Microsoft-maintained Linux distributions are permitted.",
    "category": "Kubernetes",
    "version": "2.0.0"
  }
}

